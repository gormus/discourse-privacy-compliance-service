{
  "name": "@gormus/discourse-privacy-compliance-service",
  "version": "1.1.0",
  "private": true,
  "description": "Discourse Privacy Compliance Service",
  "keywords": [
    "discourse",
    "privacy",
    "compliance",
    "api",
    "service",
    "hono"
  ],
  "license": "MIT",
  "author": {
    "name": "Osman Gormus",
    "email": "osman@gorm.us",
    "url": "https://gorm.us"
  },
  "homepage": "https://github.com/gormus/discourse-privacy-compliance-service#readme",
  "bugs": {
    "url": "https://github.com/gormus/discourse-privacy-compliance-service/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gormus/discourse-privacy-compliance-service.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "tag": "latest"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0",
    "npm": "Use pnpm package manager.",
    "yarn": "Use pnpm package manager.",
    "bun": "Use pnpm package manager."
  },
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "commit": "commit",
    "biome:check": "biome check --no-errors-on-unmatched",
    "biome:fix": "biome check --write --no-errors-on-unmatched",
    "prisma:generate": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "got": "^15.0.0",
    "hono": "^4.12.10",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "prisma": "^7.6.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.32.1"
}
