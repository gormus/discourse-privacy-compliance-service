# Environment Variables
#
# Environment name ( development | testing | staging | production )
NODE_ENV=development
#
# Hono server port.
PORT=8080
#
# Log level ( fatal | error | warn | info | debug | trace | silent )
LOG_LEVEL=debug
#
# Discourse Data Explorer query ID for looking up a user by ID.
DISCOURSE_GET_USER_BY_ID_EXPLORER_QUERY_ID=100
#
# Discourse group ID for the former staff group.
FORMER_STAFF_GROUP_ID=24
#
# Optional pipe-separated staff email domains.
STAFF_EMAIL_DOMAINS="example.com|example.org"
#
# Discourse API base URL.
DISCOURSE_API_HOST=http://localhost:4200
#
# Discourse API credentials.
DISCOURSE_API_USERNAME=REPLACE_ME
DISCOURSE_API_KEY=REPLACE_ME
#
# HTTP Authentication credentials (if defined).
DISCOURSE_AUTH_USERNAME=
DISCOURSE_AUTH_PASSWORD=
